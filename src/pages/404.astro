---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found — Chara Study Bible">
    <main class="placeholder-page">
        <div class="content">
            <h1 class="title">🚧 Coming Soon</h1>

            <div class="info-box">
                <h2>This feature requires the API backend</h2>
                <p>
                    This page is part of the API-backed study layer and will be
                    available when the backend is connected.
                </p>
            </div>

            <div class="details">
                <h3>Common API-backed features:</h3>
                <ul>
                    <li>
                        <strong>Chunk permalinks</strong> (<code>/c/...</code>)
                        — Full content view for study resource chunks
                    </li>
                    <li>
                        <strong>Tree navigation</strong> (<code>/en/...</code>)
                        — Browse by topic, source, entity, or organization
                    </li>
                    <li>
                        <strong>Entity profiles</strong> (<code
                            >/entity/...</code
                        >) — People, places, events with relationships
                    </li>
                    <li>
                        <strong>Topic pages</strong> (<code>/topic/...</code>) —
                        Thematic study with verse lists (Nave's)
                    </li>
                    <li>
                        <strong>Lexicon entries</strong> (<code
                            >/lexicon/...</code
                        >) — Hebrew/Greek word studies
                    </li>
                    <li>
                        <strong>Pericope views</strong> (<code
                            >/pericope/...</code
                        >) — All resources for a passage range
                    </li>
                </ul>
            </div>

            <div class="mock-note">
                <p>
                    <strong>Note:</strong> This is a placeholder for UI development.
                    When connected to the API backend, these pages will display live
                    data from Door43, BibleAquifer, BSB, and other resources.
                </p>
                <p>
                    The backend provides hierarchical browsing,
                    cross-references, topic lookups, entity graphs, search, and
                    RAG-powered Q&A over the full study corpus.
                </p>
            </div>

            <div class="actions">
                <a href="/" class="btn btn-primary">← Browse Bible Chapters</a>
                <a href="/q" class="btn btn-secondary" id="search-link"
                    >Search Resources</a
                >
            </div>
        </div>
    </main>
</BaseLayout>

<script is:inline>
    // Preserve search context from referrer
    function updateSearchLink() {
        const searchLink = document.getElementById("search-link");
        console.log("404 page: searchLink element:", searchLink);
        console.log("404 page: referrer:", document.referrer);

        if (searchLink && document.referrer) {
            try {
                const referrerUrl = new URL(document.referrer);
                console.log(
                    "404 page: referrer pathname:",
                    referrerUrl.pathname,
                );
                console.log("404 page: referrer search:", referrerUrl.search);

                if (referrerUrl.pathname === "/q" && referrerUrl.search) {
                    // User came from search, preserve the query params
                    const newHref = "/q" + referrerUrl.search;
                    searchLink.href = newHref;
                    console.log("404 page: updated search link to:", newHref);
                }
            } catch (e) {
                console.error("404 page: error parsing referrer:", e);
            }
        }
    }

    // Run immediately and also on DOMContentLoaded to be safe
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", updateSearchLink);
    } else {
        updateSearchLink();
    }
</script>

<style>
    .placeholder-page {
        height: 100%;
        overflow-y: auto;
        padding: 2rem 1rem;
        box-sizing: border-box;
        max-width: 800px;
        margin: 0 auto;
    }

    .content {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .title {
        margin: 0;
        font-size: 28px;
        font-weight: 700;
        color: var(--color-text);
        text-align: center;
    }

    .info-box {
        padding: 1.5rem;
        background: var(--color-primary-light);
        border: 1px solid var(--color-primary);
        border-radius: 8px;
    }

    .info-box h2 {
        margin: 0 0 0.5rem;
        font-size: 18px;
        font-weight: 600;
        color: var(--color-primary);
    }

    .info-box p {
        margin: 0;
        font-size: 14px;
        color: var(--color-text);
        line-height: 1.5;
    }

    .details {
        padding: 1rem 1.5rem;
        background: var(--color-background);
        border: 1px solid var(--color-border);
        border-radius: 8px;
    }

    .details h3 {
        margin: 0 0 0.75rem;
        font-size: 16px;
        font-weight: 600;
        color: var(--color-text);
    }

    .details ul {
        margin: 0;
        padding-left: 1.5rem;
        color: var(--color-text);
        line-height: 1.6;
    }

    .details li {
        margin-bottom: 0.5rem;
        font-size: 14px;
    }

    .details strong {
        color: var(--color-primary);
    }

    .details code {
        font-family: ui-monospace, monospace;
        font-size: 12px;
        padding: 2px 4px;
        background: var(--color-background-alt);
        border: 1px solid var(--color-border);
        border-radius: 3px;
        color: var(--color-text);
    }

    .mock-note {
        padding: 1rem 1.5rem;
        background: var(--color-background-alt);
        border-left: 4px solid var(--color-secondary);
        border-radius: 4px;
    }

    .mock-note p {
        margin: 0 0 0.75rem;
        font-size: 13px;
        color: var(--color-text);
        line-height: 1.6;
    }

    .mock-note p:last-child {
        margin-bottom: 0;
    }

    .actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn {
        padding: 0.75rem 1.5rem;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        border-radius: 8px;
        transition: all 0.2s;
        display: inline-block;
    }

    .btn-primary {
        background: var(--color-primary);
        color: white;
    }

    .btn-primary:hover {
        background: rgb(70, 111, 220);
    }

    .btn-secondary {
        background: var(--color-background);
        color: var(--color-text);
        border: 1px solid var(--color-border);
    }

    .btn-secondary:hover {
        border-color: var(--color-primary);
        color: var(--color-primary);
    }
</style>
