---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found — Chara Study Bible">
    <main class="placeholder-page">
        <div class="content">
            <h1 class="title">Route not wired yet</h1>

            <div class="info-box">
                <h2>Backend is live — this specific route is still pending</h2>
                <p>
                    The API backend is connected and most study links work
                    already. The path you followed points to a feature that
                    isn't routed in this client yet.
                </p>
            </div>

            <div class="details">
                <h3>Live now</h3>
                <ul>
                    <li>
                        <strong>BSB reader</strong> (<code>/bible/...</code>)
                        — full Bible with Strong's, served from local data
                    </li>
                    <li>
                        <strong>Search</strong> (<code>/q?q=…</code>)
                        — hits via <code>/api/search</code>; Premium toggle
                        runs RAG via <code>/api/ask</code>
                    </li>
                    <li>
                        <strong>Chunk permalinks</strong> (<code>/c/&lt;id&gt;</code>)
                        — full chunk body, tags, tree paths, cross-refs
                    </li>
                    <li>
                        <strong>Tree views</strong> (<code>/en/&lt;tree&gt;/...</code>)
                        for <code>scripture</code>, <code>source</code>,
                        <code>kind</code>, <code>term</code>,
                        <code>methodology</code>, <code>pericope</code>,
                        <code>aquifer</code>
                    </li>
                </ul>

                <h3>Not yet on the backend (stage-3 pending)</h3>
                <ul>
                    <li>
                        <strong>Topic pages</strong> (<code>/topic/...</code>) —
                        Nave's verse lists
                    </li>
                    <li>
                        <strong>Entity profiles</strong> (<code>/entity/...</code>)
                        — people, places, events with relations and maps
                    </li>
                    <li>
                        <strong>Cross-references</strong>
                        (<code>/cross-references/...</code>) — TSK + parallel
                    </li>
                    <li>
                        <strong>Concordance</strong>
                        (<code>/concordance/&lt;word&gt;</code>) — every BSB
                        verse for a word
                    </li>
                    <li>
                        <strong>Lexicon / Morphology / Transcript trees</strong>
                        (<code>/en/lexicon/...</code>,
                        <code>/en/morphology/...</code>,
                        <code>/en/transcript/...</code>)
                    </li>
                </ul>
            </div>

            <div class="mock-note">
                <p>
                    These will start working as soon as the backend ships the
                    matching builders — the client is already wired against the
                    same endpoint shapes.
                </p>
            </div>

            <div class="actions">
                <a href="/" class="btn btn-primary">← Browse Bible Chapters</a>
                <a href="/q" class="btn btn-secondary" id="search-link"
                    >Search Resources</a
                >
            </div>
        </div>
    </main>
</BaseLayout>

<script is:inline>
    // Preserve search context from referrer
    function updateSearchLink() {
        const searchLink = document.getElementById("search-link");
        if (searchLink && document.referrer) {
            try {
                const referrerUrl = new URL(document.referrer);
                // Handle both /q and /q/ (trailing slash)
                const pathname = referrerUrl.pathname.replace(/\/$/, "");
                if (pathname === "/q" && referrerUrl.search) {
                    // User came from search, preserve the query params
                    searchLink.href = "/q" + referrerUrl.search;
                }
            } catch (e) {
                // Invalid referrer URL, keep default
            }
        }
    }

    // Run immediately and also on DOMContentLoaded to be safe
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", updateSearchLink);
    } else {
        updateSearchLink();
    }
</script>

<style>
    .placeholder-page {
        height: 100%;
        overflow-y: auto;
        padding: 2rem 1rem;
        box-sizing: border-box;
        max-width: 800px;
        margin: 0 auto;
    }

    .content {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .title {
        margin: 0;
        font-size: 28px;
        font-weight: 700;
        color: var(--color-text);
        text-align: center;
    }

    .info-box {
        padding: 1.5rem;
        background: var(--color-primary-light);
        border: 1px solid var(--color-primary);
        border-radius: 8px;
    }

    .info-box h2 {
        margin: 0 0 0.5rem;
        font-size: 18px;
        font-weight: 600;
        color: var(--color-primary);
    }

    .info-box p {
        margin: 0;
        font-size: 14px;
        color: var(--color-text);
        line-height: 1.5;
    }

    .details {
        padding: 1rem 1.5rem;
        background: var(--color-background);
        border: 1px solid var(--color-border);
        border-radius: 8px;
    }

    .details h3 {
        margin: 0 0 0.75rem;
        font-size: 16px;
        font-weight: 600;
        color: var(--color-text);
    }

    .details ul {
        margin: 0;
        padding-left: 1.5rem;
        color: var(--color-text);
        line-height: 1.6;
    }

    .details li {
        margin-bottom: 0.5rem;
        font-size: 14px;
    }

    .details strong {
        color: var(--color-primary);
    }

    .details code {
        font-family: ui-monospace, monospace;
        font-size: 12px;
        padding: 2px 4px;
        background: var(--color-background-alt);
        border: 1px solid var(--color-border);
        border-radius: 3px;
        color: var(--color-text);
    }

    .mock-note {
        padding: 1rem 1.5rem;
        background: var(--color-background-alt);
        border-left: 4px solid var(--color-secondary);
        border-radius: 4px;
    }

    .mock-note p {
        margin: 0 0 0.75rem;
        font-size: 13px;
        color: var(--color-text);
        line-height: 1.6;
    }

    .mock-note p:last-child {
        margin-bottom: 0;
    }

    .actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn {
        padding: 0.75rem 1.5rem;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        border-radius: 8px;
        transition: all 0.2s;
        display: inline-block;
    }

    .btn-primary {
        background: var(--color-primary);
        color: white;
    }

    .btn-primary:hover {
        background: rgb(70, 111, 220);
    }

    .btn-secondary {
        background: var(--color-background);
        color: var(--color-text);
        border: 1px solid var(--color-border);
    }

    .btn-secondary:hover {
        border-color: var(--color-primary);
        color: var(--color-primary);
    }
</style>
