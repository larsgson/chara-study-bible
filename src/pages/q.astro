---
import BaseLayout from "../layouts/BaseLayout.astro";

const q = Astro.url.searchParams.get("q")?.trim() ?? "";
const mode =
    Astro.url.searchParams.get("mode") === "premium" ? "Premium" : "Free";
---

<BaseLayout
    title={q
        ? `${q} — Search — Chara Study Bible`
        : "Search — Chara Study Bible"}
>
    <main class="page">
        <h1 class="title">{q ? `Search: "${q}"` : "Search"}</h1>
        <p class="mode-badge">{mode} Search</p>

        <p class="muted">
            Search runs on the API backend. The frontend is wired up; once the
            backend is reachable (set <code>PUBLIC_API_BASE_URL</code>), results
            will appear here.
        </p>

        <p class="muted">
            In the meantime, the BSB reader and Strong's lookups are fully
            functional locally —
            <a href="/" class="link">pick a passage</a>.
        </p>
    </main>
</BaseLayout>

<style>
    .page {
        height: 100%;
        overflow-y: auto;
        padding: 1.25rem 1rem;
        box-sizing: border-box;
    }
    .title {
        margin: 0 0 0.5rem;
        font-size: 20px;
        font-weight: 600;
        color: var(--color-text);
    }
    .mode-badge {
        display: inline-block;
        margin: 0 0 0.75rem;
        padding: 4px 10px;
        font-size: 12px;
        font-weight: 600;
        color: var(--color-primary);
        background: var(--color-primary-light);
        border-radius: 6px;
    }
    .muted {
        margin: 0 0 0.75rem;
        color: var(--color-text-muted);
        font-size: 14px;
        line-height: 1.55;
    }
    .muted code {
        font-family: ui-monospace, monospace;
        font-size: 12px;
        padding: 1px 5px;
        background: var(--color-background-alt);
        border: 1px solid var(--color-border);
        border-radius: 4px;
    }
    .link {
        color: var(--color-primary);
        text-decoration: none;
    }
    .link:hover {
        text-decoration: underline;
    }
</style>
