---
// Global header — persistent on every page.
// Logo (home link) + search input that submits to /q.
const initialQuery =
    Astro.url?.pathname === "/q" ? (Astro.url.searchParams.get("q") ?? "") : "";
const initialMode =
    Astro.url?.pathname === "/q"
        ? (Astro.url.searchParams.get("mode") ?? "free")
        : "free";
---

<header class="app-header">
    <a href="/" class="brand" aria-label="Chara Study Bible — home">Chara</a>
    <form
        class="search"
        action="/q"
        method="get"
        role="search"
        id="search-form"
    >
        <div class="search-controls">
            <input
                type="search"
                name="q"
                placeholder="Search…"
                aria-label="Search"
                autocomplete="off"
                value={initialQuery}
                class="search-input"
            />
            <input
                type="hidden"
                name="password"
                id="premium-password"
                value=""
            />
            <div class="toggle-container">
                <label class="toggle-switch">
                    <input
                        type="checkbox"
                        name="mode"
                        value="premium"
                        checked={initialMode === "premium"}
                        class="toggle-checkbox"
                        id="mode-toggle"
                    />
                    <span class="toggle-slider"></span>
                    <span class="toggle-label toggle-label-free">Free</span>
                    <span class="toggle-label toggle-label-premium"
                        >Premium</span
                    >
                </label>
            </div>
        </div>
    </form>
</header>

<div id="password-modal" class="modal" style="display: none;">
    <div class="modal-content">
        <h2 class="modal-title">Premium Search</h2>
        <p class="modal-text">Please enter your premium password:</p>
        <input
            type="password"
            id="password-input"
            class="password-input"
            placeholder="Enter password"
            autocomplete="off"
        />
        <div class="modal-buttons">
            <button type="button" id="password-cancel" class="btn btn-cancel"
                >Cancel</button
            >
            <button type="button" id="password-submit" class="btn btn-submit"
                >Continue</button
            >
        </div>
    </div>
</div>

<style>
    .app-header {
        flex: 0 0 auto;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        height: 48px;
        padding: 0 0.75rem;
        background: var(--color-background);
        border-bottom: 1px solid var(--color-border);
    }
    .brand {
        flex: 0 0 auto;
        font-size: 16px;
        font-weight: 700;
        color: var(--color-text);
        text-decoration: none;
        letter-spacing: -0.01em;
    }
    .brand:hover {
        color: var(--color-primary);
    }
    .search {
        flex: 1 1 auto;
        display: flex;
        margin: 0;
    }
    .search-controls {
        flex: 1 1 auto;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .search-input {
        flex: 1 1 auto;
        width: 100%;
        height: 32px;
        padding: 0 0.6rem;
        font-size: 14px;
        font-family: inherit;
        color: var(--color-text);
        background: var(--color-background-alt);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        outline: none;
    }
    .search-input::placeholder {
        color: var(--color-text-muted);
    }
    .search-input:focus {
        border-color: var(--color-primary);
    }
    .toggle-container {
        flex: 0 0 auto;
    }
    .toggle-switch {
        position: relative;
        display: inline-flex;
        align-items: center;
        width: 140px;
        height: 32px;
        cursor: pointer;
        user-select: none;
    }
    .toggle-checkbox {
        position: absolute;
        opacity: 0;
        width: 0;
        height: 0;
    }
    .toggle-slider {
        position: absolute;
        width: 100%;
        height: 100%;
        background: var(--color-background-alt);
        border: 1px solid var(--color-border);
        border-radius: 16px;
        transition: all 0.3s ease;
    }
    .toggle-slider::before {
        content: "";
        position: absolute;
        left: 2px;
        top: 2px;
        width: 66px;
        height: 26px;
        background: var(--color-primary);
        border-radius: 13px;
        transition: transform 0.3s ease;
    }
    .toggle-checkbox:checked + .toggle-slider::before {
        transform: translateX(68px);
        background: var(--color-accent);
    }
    .toggle-label {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        font-size: 12px;
        font-weight: 600;
        pointer-events: none;
        transition: all 0.3s ease;
        z-index: 1;
    }
    .toggle-label-free {
        left: 12px;
        color: white;
    }
    .toggle-label-premium {
        right: 12px;
        color: var(--color-text-muted);
    }
    .toggle-checkbox:checked ~ .toggle-label-free {
        color: var(--color-text-muted);
    }
    .toggle-checkbox:checked ~ .toggle-label-premium {
        color: white;
    }
    .modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }
    .modal-content {
        background: var(--color-background);
        padding: 1.5rem;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
        width: 90%;
        max-width: 400px;
    }
    .modal-title {
        margin: 0 0 0.5rem;
        font-size: 18px;
        font-weight: 600;
        color: var(--color-text);
    }
    .modal-text {
        margin: 0 0 1rem;
        font-size: 14px;
        color: var(--color-text-muted);
    }
    .password-input {
        width: 100%;
        height: 36px;
        padding: 0 0.75rem;
        font-size: 14px;
        font-family: inherit;
        color: var(--color-text);
        background: var(--color-background-alt);
        border: 1px solid var(--color-border);
        border-radius: 8px;
        outline: none;
        box-sizing: border-box;
        margin-bottom: 1rem;
    }
    .password-input:focus {
        border-color: var(--color-primary);
    }
    .modal-buttons {
        display: flex;
        gap: 0.75rem;
        justify-content: flex-end;
    }
    .btn {
        padding: 0.5rem 1rem;
        font-size: 14px;
        font-weight: 600;
        font-family: inherit;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .btn-cancel {
        background: var(--color-background-alt);
        color: var(--color-text);
        border: 1px solid var(--color-border);
    }
    .btn-cancel:hover {
        background: var(--color-border);
    }
    .btn-submit {
        background: var(--color-primary);
        color: white;
    }
    .btn-submit:hover {
        background: rgb(70, 111, 220);
    }
</style>

<script>
    const toggle = document.getElementById("mode-toggle") as HTMLInputElement;
    const modal = document.getElementById("password-modal") as HTMLElement;
    const passwordInput = document.getElementById(
        "password-input",
    ) as HTMLInputElement;
    const passwordHidden = document.getElementById(
        "premium-password",
    ) as HTMLInputElement;
    const passwordSubmit = document.getElementById(
        "password-submit",
    ) as HTMLButtonElement;
    const passwordCancel = document.getElementById(
        "password-cancel",
    ) as HTMLButtonElement;
    const searchForm = document.getElementById(
        "search-form",
    ) as HTMLFormElement;

    const STORAGE_KEY = "premium_password";

    // Check if password exists in session storage
    const storedPassword = sessionStorage.getItem(STORAGE_KEY);
    if (storedPassword) {
        passwordHidden.value = storedPassword;
    }

    toggle.addEventListener("change", function (e) {
        if (this.checked) {
            // Switching to premium
            const password = sessionStorage.getItem(STORAGE_KEY);
            if (!password) {
                // Show password modal
                e.preventDefault();
                modal.style.display = "flex";
                passwordInput.focus();
            } else {
                // Password already exists, use it
                passwordHidden.value = password;
            }
        } else {
            // Switching to free, clear password from form
            passwordHidden.value = "";
        }
    });

    passwordSubmit.addEventListener("click", function () {
        const password = passwordInput.value.trim();
        if (password) {
            // Store password in session storage
            sessionStorage.setItem(STORAGE_KEY, password);
            passwordHidden.value = password;
            modal.style.display = "none";
            passwordInput.value = "";
            toggle.checked = true;
        } else {
            passwordInput.focus();
        }
    });

    passwordCancel.addEventListener("click", function () {
        modal.style.display = "none";
        passwordInput.value = "";
        toggle.checked = false;
        passwordHidden.value = "";
    });

    // Allow Enter key to submit password
    passwordInput.addEventListener("keydown", function (e) {
        if (e.key === "Enter") {
            e.preventDefault();
            passwordSubmit.click();
        }
    });

    // Close modal on Escape key
    document.addEventListener("keydown", function (e) {
        if (e.key === "Escape" && modal.style.display === "flex") {
            passwordCancel.click();
        }
    });

    // Set password field on form submit if premium is selected
    searchForm.addEventListener("submit", function () {
        if (toggle.checked) {
            const password = sessionStorage.getItem(STORAGE_KEY);
            if (password) {
                passwordHidden.value = password;
            }
        }
    });
</script>
