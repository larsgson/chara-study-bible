---
import Header from '../components/Header.astro'

interface Props {
  title?: string
}

const { title = 'Chara Study Bible' } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Mobile-first Bible study app — BSB reader plus API-backed study tools" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="app-shell">
    <Header />
    <div class="app-main">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";

  body.app-shell {
    display: flex;
    flex-direction: column;
    height: 100dvh;
    margin: 0;
    overflow: hidden;
  }
  .app-main {
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }
  .app-main > * {
    flex: 1 1 auto;
    min-height: 0;
  }
</style>
