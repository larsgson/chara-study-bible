    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "~5.7.3"
